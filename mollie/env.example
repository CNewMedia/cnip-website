# Kopieer dit bestand naar .env.local voor lokaal testen
# Voeg deze variabelen ook toe in het Vercel dashboard onder Settings > Environment Variables

# Jouw Mollie OAuth app gegevens
MOLLIE_CLIENT_ID=app_xxxxxxxxxxxxxxxx
MOLLIE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# De Vercel callback URL (pas aan na deployment)
MOLLIE_REDIRECT_URI=https://jouw-vercel-app.vercel.app/api/callback

# De URL van je GitHub Pages site
FRONTEND_URL=https://jouw-gebruikersnaam.github.io/cnip

# Vercel KV (automatisch ingevuld door Vercel na koppelen KV database)
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=
